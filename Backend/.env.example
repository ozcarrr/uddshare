# MySQL connection string
# Format: mysql+pymysql://username:password@host:port/database
# Example: mysql+pymysql://root:mypassword@localhost:3306/uddshare
MYSQL_URL=mysql+pymysql://root:password@localhost:3306/uddshare

# JWT secret — change this to any long random string in production
SECRET_KEY=super-secret-key-change-this

# Token expiry in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ENVIRONMENT=development
